/* ======================= ADDRESSES ======================= */

#define MPU6050_ADDR        (0x68 << 1)
#define MMC5603_ADDR        (0x30 << 1)

/* ======================= MPU REG ======================= */

#define MPU_PWR1            0x6B
#define MPU_ACCEL_XOUT      0x3B

/* ======================= MMC REG ======================= */

#define MMC_REG_DATA        0x00
#define MMC_REG_STATUS      0x18
#define MMC_REG_CTRL0       0x1B
#define MMC_REG_CTRL1       0x1C
#define MMC_REG_CTRL2       0x1D

#define MMC_CMD_SET         0x08
#define MMC_CMD_RESET       0x10
#define MMC_CMD_TM          0x01

/* ======================= VARIABLES ======================= */

int16_t ax,ay,az,gx,gy,gz;
int32_t mx1,my1,mz1;
int32_t mx2,my2,mz2;

uint8_t usbBuf[128];

I2C_HandleTypeDef hi2c1;
I2C_HandleTypeDef hi2c2;


void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_I2C1_Init(void);
static void MX_I2C2_Init(void);

void mpu_init()
{
    uint8_t d;
    d = 0x80;
    HAL_I2C_Mem_Write(&hi2c2, MPU6050_ADDR, 0x6B, 1, &d, 1, 100);  // ? hi2c2
    HAL_Delay(100);

    d = 0x01;
    HAL_I2C_Mem_Write(&hi2c2, MPU6050_ADDR, 0x6B, 1, &d, 1, 100);  // ? hi2c2
    HAL_Delay(50);

    d = 0x01;
    HAL_I2C_Mem_Write(&hi2c2, MPU6050_ADDR, 0x19, 1, &d, 1, 100);  // ? hi2c2

    d = 0x03;
    HAL_I2C_Mem_Write(&hi2c2, MPU6050_ADDR, 0x1A, 1, &d, 1, 100);  // ? hi2c2

    d = 0x00;
    HAL_I2C_Mem_Write(&hi2c2, MPU6050_ADDR, 0x1C, 1, &d, 1, 100);  // ? hi2c2
}

void mpu_read()
{
    uint8_t buf[6];
    HAL_I2C_Mem_Read(&hi2c2, MPU6050_ADDR, 0x3B, 1, buf, 6, 100);  // ? hi2c2

    ax = (int16_t)((buf[0] << 8) | buf[1]);
    ay = (int16_t)((buf[2] << 8) | buf[3]);
    az = (int16_t)((buf[4] << 8) | buf[5]);
}



/* ======================= MMC ======================= */

void mmc_set_reset(I2C_HandleTypeDef *hi2c)
{
    uint8_t d;

    d = MMC_CMD_SET;
    HAL_I2C_Mem_Write(hi2c,MMC5603_ADDR,MMC_REG_CTRL0,1,&d,1,100);
    HAL_Delay(3);

    d = MMC_CMD_RESET;
    HAL_I2C_Mem_Write(hi2c,MMC5603_ADDR,MMC_REG_CTRL0,1,&d,1,100);
    HAL_Delay(3);
}

void mmc_read(I2C_HandleTypeDef *hi2c,int32_t *mx,int32_t *my,int32_t *mz)
{
    uint8_t buf[7];
    uint8_t cmd = 0x01;

    HAL_I2C_Mem_Write(hi2c,MMC5603_ADDR,0x1B,1,&cmd,1,100);

    HAL_Delay(1);

    HAL_I2C_Mem_Read(hi2c,MMC5603_ADDR,0x00,1,buf,7,100);

    *mx = ((uint32_t)buf[0]<<12) | ((uint32_t)buf[1]<<4) | (buf[6]>>4);
    *my = ((uint32_t)buf[2]<<12) | ((uint32_t)buf[3]<<4) | ((buf[6]>>2)&0x03);
    *mz = ((uint32_t)buf[4]<<12) | ((uint32_t)buf[5]<<4) | (buf[6]&0x03);

    *mx -= 524288;
    *my -= 524288;
    *mz -= 524288;
}

/* ======================= USB SEND ======================= */

void usb_send()
{
    int len = sprintf((char*)usbBuf,
        "%d,%d,%d,%ld,%ld,%ld,%ld,%ld,%ld\r\n",
        ax,ay,az,
        mx1,my1,mz1,
        mx2,my2,mz2);

    CDC_Transmit_FS(usbBuf,len);
}
 
int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_I2C1_Init();
    MX_I2C2_Init();
    MX_USB_DEVICE_Init();

    HAL_Delay(2000);

    mpu_init();

    mmc_set_reset(&hi2c1);
    mmc_set_reset(&hi2c2);

    uint32_t last = HAL_GetTick();

    while(1)
    {
        if(HAL_GetTick()-last >= 2)
        {
            last = HAL_GetTick();

            mpu_read();

            mmc_read(&hi2c1,&mx1,&my1,&mz1);
            mmc_read(&hi2c2,&mx2,&my2,&mz2);

            usb_send();
        }
    }
}

