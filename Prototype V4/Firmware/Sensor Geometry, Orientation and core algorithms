## Core Algorithm

### 1. Dipole Recovery (verified zero mathematical error)
```python
S1_pos = np.array([ 0.0, -1.0,  1.1])
S2_pos = np.array([ 1.2,  0.0,  1.1])

def jac(r):
    rn = np.linalg.norm(r); rh = r/rn
    return (3*np.outer(rh,rh) - np.eye(3)) / rn**3

A = np.vstack([R_S1 @ jac(S1_pos),
               R_S2 @ jac(S2_pos)])   # 6x3 matrix

PINV_A = np.linalg.pinv(A)            # 3x6 pseudo-inverse

def extract_dipole(raw1, raw2):
    scale = (np.linalg.norm(raw1) + np.linalg.norm(raw2)) / 2
    if scale < 1e-9: return None
    b = np.concatenate([raw1, raw2]) / scale
    m = PINV_A @ b
    n = np.linalg.norm(m)
    return m/n if n > 1e-9 else None
```

### 2. Gravity Recovery
```python
def recover_gravity(raw_accel):
    g = R_acc.T @ raw_accel
    n = np.linalg.norm(g)
    return -g/n  # NEGATED — accel reads opposite to gravity direction
```

### 3. Compass Recovery
```python
def recover_compass(raw_compass):
    b = R_compass.T @ raw_compass
    n = np.linalg.norm(b)
    return b/n if n > 1e-9 else np.array([0.,1.,0.])
```

### 4. World Frame Construction
```python
def build_world_frame(gravity_hat, compass_hat):
    down      = gravity_hat / np.linalg.norm(gravity_hat)
    north_raw = compass_hat - np.dot(compass_hat, down) * down
    nn        = np.linalg.norm(north_raw)
    north     = north_raw/nn if nn > 1e-6 else np.array([0.,1.,0.])
    east      = np.cross(north, down)
    east      = east / np.linalg.norm(east)
    return east, north, down
```

### 5. Rotation Vector (core tracking)
```python
rv = np.cross(cycle_ref_m, m_curr)
# |rv| = dα × sin(θ)
# where θ = angle between dipole and rotation axis
# dα = rotation angle between frames
```

### 6. Canvas Mapping
```python
rv_h  = rv - np.dot(rv, down) * down   # project to horizontal plane
dx_mm = np.dot(rv_h, east)  * MM_PER_RAD  # canvas X (right)
dy_mm = np.dot(rv_h, north) * MM_PER_RAD  # canvas Y (forward)
```

### 7. Cyclic Reset (eliminates drift)
```python
CYCLE_FRAMES = 5  # reset every 5 frames = every 10ms at 500Hz

if frame_count >= CYCLE_FRAMES:
    cycle_ref_m      = m_curr.copy()   # reset dipole reference
    cycle_ref_canvas = canvas_pts[-1]  # continue from last point
    frame_count      = 0
```

### 8. Sphere Rotation (for 3D visualiser)
```python
rv     = np.cross(ref_m, m_curr)
rv_mag = np.linalg.norm(rv)
if rv_mag > 1e-6:
    axis  = rv / rv_mag
    angle = rv_mag  # small angle approximation valid at 500Hz
    c=np.cos(angle); s=np.sin(angle); t=1-c
    x,y,z = axis
    dR = np.array([[t*x*x+c,   t*x*y-s*z, t*x*z+s*y],
                   [t*x*y+s*z, t*y*y+c,   t*y*z-s*x],
                   [t*x*z-s*y, t*y*z+s*x, t*z*z+c  ]])
    sphere_rot = dR @ sphere_rot

# Re-orthogonalise every 200 frames to prevent drift
if frame_count % 200 == 0:
    U, _, Vt = np.linalg.svd(sphere_rot)
    sphere_rot = U @ Vt
```

