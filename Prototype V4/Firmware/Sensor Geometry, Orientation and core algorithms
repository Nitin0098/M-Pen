## Firmware (main.c) Key Functions

```c
// Addresses
#define MPU6050_ADDR  (0x68 << 1)
#define MMC5603_ADDR  (0x30 << 1)

// MMC5603 registers
#define MMC_REG_DATA  0x00
#define MMC_REG_CTRL0 0x1B
#define MMC_CMD_SET   0x08
#define MMC_CMD_RESET 0x10
#define MMC_CMD_TM    0x01

// Variables
int16_t ax, ay, az;
int32_t mx1,my1,mz1;  // S1
int32_t mx2,my2,mz2;  // S2
int32_t mx3,my3,mz3;  // S3 compass

// Init all three MMC5603s
mmc_set_reset(&hi2c1);
mmc_set_reset(&hi2c2);
mmc_set_reset(&hi2c3);

// Main loop (2ms = 500Hz)
while(1) {
    if(HAL_GetTick()-last >= 2) {
        last = HAL_GetTick();
        mpu_read();
        mmc_read(&hi2c1, &mx1,&my1,&mz1);
        mmc_read(&hi2c2, &mx2,&my2,&mz2);
        mmc_read(&hi2c3, &mx3,&my3,&mz3);
        usb_send();
    }
}

// Serial output
sprintf(buf, "%d,%d,%d,%ld,%ld,%ld,%ld,%ld,%ld,%ld,%ld,%ld\r\n",
        ax,ay,az,
        mx1,my1,mz1,
        mx2,my2,mz2,
        mx3,my3,mz3);
```

